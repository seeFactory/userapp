{
  "name": "seefactory-miniapp",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "description": "seeFactory mini program prototype built with React and Taro.",
  "scripts": {
    "dev:h5": "taro build --type h5 --watch",
    "build:h5": "pnpm clean:dist && pnpm prepare:h5-dist && taro build --type h5 && pnpm postbuild:h5 && pnpm verify:h5-size",
    "build:h5:prod": "node scripts/build-production.mjs h5",
    "postbuild:h5": "node scripts/postprocess-h5-cache-bust.mjs",
    "dev:tma": "taro build --type h5 --watch",
    "build:tma": "pnpm build:h5",
    "build:tma:prod": "node scripts/build-production.mjs telegram-tma",
    "dev:weapp": "taro build --type weapp --watch",
    "build:weapp": "pnpm clean:dist && taro build --type weapp",
    "dev:alipay": "taro build --type alipay --watch",
    "build:alipay": "pnpm clean:dist && taro build --type alipay",
    "dev:tt": "taro build --type tt --watch",
    "build:tt": "pnpm clean:dist && taro build --type tt",
    "dev:qq": "taro build --type qq --watch",
    "build:qq": "pnpm clean:dist && taro build --type qq",
    "build:all": "pnpm build:h5 && pnpm build:weapp && pnpm build:alipay && pnpm build:tt && pnpm build:qq",
    "verify:runtime-contract": "node scripts/verify-runtime-contract.mjs",
    "verify:env-example": "node scripts/verify-env-example.mjs",
    "verify:feedback-system": "node scripts/verify-feedback-system.mjs",
    "verify:branch-diff": "node scripts/verify-branch-diff.mjs",
    "verify:production-api": "node scripts/verify-production-api-base.mjs",
    "verify:tma-dist": "node scripts/verify-tma-dist.mjs",
    "verify": "pnpm verify:runtime-contract && pnpm verify:env-example && pnpm verify:feedback-system && pnpm verify:branch-diff && pnpm build:all",
    "clean:dist": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "prepare:h5-dist": "node scripts/prepare-h5-dist.mjs",
    "preview:h5": "node scripts/preview-static.mjs",
    "verify:h5-size": "node scripts/verify-h5-size.mjs"
  },
  "dependencies": {
    "@babel/runtime": "^7.28.4",
    "@tarojs/components": "4.2.0",
    "@tarojs/helper": "4.2.0",
    "@tarojs/plugin-framework-react": "4.2.0",
    "@tarojs/plugin-platform-h5": "4.2.0",
    "@tarojs/plugin-platform-weapp": "4.2.0",
    "@tarojs/react": "4.2.0",
    "@tarojs/runtime": "4.2.0",
    "@tarojs/shared": "4.2.0",
    "@tarojs/taro": "4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/preset-react": "^7.28.5",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.5.17",
    "@tarojs/cli": "4.2.0",
    "@tarojs/plugin-platform-alipay": "4.2.0",
    "@tarojs/plugin-platform-qq": "4.2.0",
    "@tarojs/plugin-platform-tt": "4.2.0",
    "@tarojs/webpack5-runner": "4.2.0",
    "babel-preset-taro": "4.2.0",
    "webpack": "5.91.0"
  }
}
